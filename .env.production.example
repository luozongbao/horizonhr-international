# ──────────────────────────────────────────────────────────────────────────────
# HRINT Production Environment Variables
# Copy this file to .env (at project root) and fill in all values before deploy.
# NEVER commit the filled .env file — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=HRINT
APP_ENV=production
# Generate with: docker compose -f docker-compose.prod.yml exec app php artisan key:generate
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=horizon_international
DB_USERNAME=hrint
# Use a strong password (min 20 chars, mixed case + symbols)
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Cache / Queue / Session ────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=oss
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Aliyun OSS (Object Storage) ───────────────────────────────────────────────
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ENDPOINT=
# Public URL prefix for serving stored files
OSS_URL=

# AWS/S3-compatible (maps to OSS for league/flysystem-aws-s3-v3)
AWS_ACCESS_KEY_ID="${OSS_ACCESS_KEY_ID}"
AWS_SECRET_ACCESS_KEY="${OSS_ACCESS_KEY_SECRET}"
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET="${OSS_BUCKET}"
AWS_ENDPOINT="${OSS_ENDPOINT}"
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Tencent RTC (1:1 video interview) ─────────────────────────────────────────
TRTC_SDK_APP_ID=
TRTC_SECRET_KEY=

# ── Tencent CSS Live Streaming (Seminar broadcasting) ─────────────────────────
TRTC_PUSH_DOMAIN=
TRTC_PLAY_DOMAIN=
TRTC_PUSH_KEY=
TRTC_PLAY_KEY=
TRTC_APP_NAME=live
TRTC_CALLBACK_HASH_KEY=

# ── Social OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ── Mail ──────────────────────────────────────────────────────────────────────
# Production SMTP credentials are managed via the Admin → Settings panel in the DB.
# These env values serve as fallback when no DB settings exist yet.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME=HRINT

# ── Vite (used at build time only — not at runtime) ───────────────────────────
VITE_APP_NAME="${APP_NAME}"
