APP_NAME=HRINT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=hrint
DB_USERNAME=hrint
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# OSS (Aliyun Object Storage — S3-compatible)
# Leave OSS_BUCKET empty to fall back to local public disk (development mode)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ENDPOINT=
OSS_URL=

# TRTC (Tencent RTC — 1:1 video interview)
TRTC_SDK_APP_ID=
TRTC_SECRET_KEY=

# Tencent CSS Live Streaming (Seminar broadcasting)
TRTC_PUSH_DOMAIN=
TRTC_PLAY_DOMAIN=
TRTC_PUSH_KEY=
TRTC_PLAY_KEY=
TRTC_APP_NAME=live

# Social OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Mail — development uses Mailpit (web UI: http://localhost:8025, SMTP: mailpit:1025)
# Production SMTP credentials are stored in the admin Settings DB and applied at runtime.
# These env values serve as fallback when no DB settings exist yet.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@horizonhr.com
MAIL_FROM_NAME=HorizonHR

# AWS / S3 (used for league/flysystem-aws-s3-v3 with OSS-compatible endpoint)
AWS_ACCESS_KEY_ID="${OSS_ACCESS_KEY_ID}"
AWS_SECRET_ACCESS_KEY="${OSS_ACCESS_KEY_SECRET}"
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET="${OSS_BUCKET}"
AWS_ENDPOINT="${OSS_ENDPOINT}"
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
